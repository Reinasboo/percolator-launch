# ============================================================================
# LOCAL ENVIRONMENT CONFIG (SECRETS) — .env.local
# ============================================================================
# 🔒 DO NOT COMMIT THIS FILE
# This template shows what secrets need to be set in your local .env.local file
# All values below should be replaced with your actual credentials
# 
# Setup:
# 1. cp .env.local.example .env.local
# 2. Edit .env.local with your actual secrets
# 3. .env.local is gitignored - never committed
# ============================================================================

# HELIUS API KEY (Optional for devnet, required for mainnet)
# Get from: https://dev.helius.xyz/dashboard
HELIUS_API_KEY=your_helius_api_key_here

# DATABASE CREDENTIALS
# Get from Supabase: https://app.supabase.com/projects
# Project Settings → API → URLs and Keys
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# API AUTHENTICATION KEYS
# Generate with: openssl rand -hex 32 (or use your preferred method)
API_AUTH_KEY=your-api-auth-key-here
WS_AUTH_SECRET=your-websocket-secret-here

# SOLANA KEYPAIRS (DEVNET ONLY - Never use mainnet keys here)
# ⚠️ CRITICAL SECURITY:
# - NEVER paste mainnet private keys
# - NEVER commit this file
# - Rotate these keys frequently
# - Consider using a signer service for production
#
# Generate devnet keypair:
# solana-keygen new --no-bip39-passphrase
# Then run: solana-keygen show ~/.config/solana/id.json -o json-compact
# Copy the seed phrase array output below
#
CRANK_KEYPAIR=[YOUR_DEVNET_KEYPAIR_SEED_ARRAY_HERE]
ADMIN_KEYPAIR=[YOUR_DEVNET_ADMIN_KEYPAIR_SEED_ARRAY_HERE]
DEVNET_MINT_AUTHORITY_KEYPAIR=[YOUR_DEVNET_MINT_AUTHORITY_SEED_ARRAY_HERE]

# OPTIONAL: RPC ENDPOINT OVERRIDE
# Leave empty to use defaults from .env
# RPC_URL=https://api.devnet.solana.com

# ============================================================================
# SECURITY REMINDERS
# ============================================================================
# ✅ DO:
#   - Keep .env.local in .gitignore (it already is)
#   - Use strong, unique API keys
#   - Rotate keys periodically
#   - Use environment variables in production (not files)
#   - Consider HashiCorp Vault or AWS Secrets Manager for team

# ❌ DON'T:
#   - Commit .env.local
#   - Paste mainnet private keys
#   - Share .env.local files
#   - Use the same keys across environments
#   - Keep keypairs as environment variables in production
